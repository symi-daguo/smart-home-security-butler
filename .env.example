# 智能家居 AI 安全管家 - 环境变量模板
# 复制为 .env 后填入真实值：cp .env.example .env

# 时区
TZ=Asia/Shanghai

# 运行环境
NODE_ENV=production

# 数据存储目录
DATA_DIR=/app/data

# 服务端口
PORT=3000

# OpenRouter API（AI 对话必填）
OPENROUTER_API_KEY=
OPENROUTER_MODEL=nvidia/nemotron-3-super-120b-a12b:free
OPENROUTER_FALLBACK_MODEL=openrouter/free

# Home Assistant（CasaOS 同机容器默认用 bridge 网关访问 host 网络）
HA_BASE_URL=http://172.17.0.1:8123
HA_TOKEN=

# Node-RED（可选）
NODERED_BASE_URL=http://172.17.0.1:1880
NODERED_TOKEN=

# KNX 网关（可配置两台，可选）
KNX_BASE_URL=
KNX_TOKEN=
KNX2_BASE_URL=
KNX2_TOKEN=

# Telegram 通知（可选）
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Bark iOS 推送（可选）
BARK_DEVICE_KEY=
BARK_BASE_URL=https://api.day.app

# Server酱 微信推送（可选）
SERVERCHAN_SEND_KEY=

# 检测间隔（毫秒，默认5分钟）
DETECTION_INTERVAL=300000

# 日志级别
LOG_LEVEL=info
